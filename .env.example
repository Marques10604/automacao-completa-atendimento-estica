# Este arquivo é versionado no git — NUNCA coloque credenciais reais aqui.
# Só placeholders. As chaves de verdade vão no .env (que está no .gitignore)
# e nas variáveis de ambiente do Railway.

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Identidade padrão (fallback — sobrescrita pelos dados do tenant no Supabase)
DEFAULT_CLINIC_NAME=Clínica Exemplo
DEFAULT_PROFESSIONAL_NAME=Assistente Virtual

# ── WhatsApp Cloud API (Meta Business) ────────────────────────────────────────
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=

# ── Webhook ────────────────────────────────────────────────────────────────────
# Você escolhe esse valor; tem que ser o mesmo registrado no Meta Business Manager.
VERIFY_TOKEN=

# ── Transcrição de áudio (Groq / Whisper large-v3-turbo) ──────────────────────
# Opcional. Sem essa chave o agente não transcreve nota de voz — ele volta a
# responder que só processa texto, sem quebrar nada. Gere em console.groq.com/keys
GROQ_API_KEY=

# ── Segurança (endpoints admin) ────────────────────────────────────────────────
ADMIN_API_KEY=

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=8000
